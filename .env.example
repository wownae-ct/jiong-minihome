# Database (MariaDB)
DATABASE_URL="mysql://username:password@localhost:3306/minihompi"

# NextAuth.js
AUTH_URL="http://localhost:3000"
AUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"

# OAuth - Kakao
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""

# OAuth - Naver
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""

# OAuth - Google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Gmail SMTP (비밀번호 찾기 이메일 발송)
# Google 계정 2단계 인증 활성화 후 앱 비밀번호 생성 필요
# https://myaccount.google.com/apppasswords
GMAIL_USER=""
GMAIL_APP_PASSWORD=""

# MinIO S3 Storage
MINIO_ENDPOINT="http://minio.example.com:9000"        # 서버→MinIO 내부 통신 (S3 SDK용)
MINIO_PUBLIC_URL="https://example.com/s3"              # 브라우저→MinIO 공개 URL (nginx 프록시 경유)
MINIO_ACCESS_KEY="your-access-key"
MINIO_SECRET_KEY="your-secret-key"
MINIO_BUCKET="portfolio-web"
MINIO_REGION="us-east-1"
MINIO_IMAGE_HOSTNAME="example.com"
